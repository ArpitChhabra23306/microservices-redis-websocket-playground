    {
      "id": "Ql6wtbrKV5KmyuP8PYFbZ",
      "type": "text",
      "x": 3559.9966911348015,
      "y": -6163.711072986263,
      "width": 1037.198232170844,
      "height": 90,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1P",
      "roundness": null,
      "seed": 656498485,
      "version": 94,
      "versionNonce": 1377822261,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783641094397,
      "link": null,
      "locked": false,
      "text": "Definition: A WebSocket provides a persistent, full-duplex\ncommunication channel over a single TCP connection.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Definition: A WebSocket provides a persistent, full-duplex communication channel over a single TCP connection.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "HRftRXbZj7kiM-qF5E-WR",
      "type": "text",
      "x": 3552.2276510692154,
      "y": -6033.7752942072875,
      "width": 1032.1268481729212,
      "height": 135,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1Q",
      "roundness": null,
      "seed": 1569659547,
      "version": 101,
      "versionNonce": 1376737173,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783641094397,
      "link": null,
      "locked": false,
      "text": "Primary Scope: It is almost exclusively used for Browser-\nto-Server communication. It is rarely used for backend-to-\nbackend communication.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Primary Scope: It is almost exclusively used for Browser-to-Server communication. It is rarely used for backend-to-backend communication.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "oA94Ig8nqkQy1o-PSlb86",
      "type": "text",
      "x": 3551.1040080095036,
      "y": -5852.194161582144,
      "width": 1028.753631243684,
      "height": 180,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1R",
      "roundness": null,
      "seed": 1517924501,
      "version": 118,
      "versionNonce": 2043256053,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783641094397,
      "link": null,
      "locked": false,
      "text": "Full-Duplex: This means both the browser and the server\ncan send data to each other at any time. (In standard\nHTTP, the server can never initiate sending data to a\nbrowser; the browser must request it first).",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Full-Duplex: This means both the browser and the server can send data to each other at any time. (In standard HTTP, the server can never initiate sending data to a browser; the browser must request it first).",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "oorwaRkiACTMnwxiV9w3a",
      "type": "text",
      "x": 3553.493027837986,
      "y": -6244.587686839407,
      "width": 395.74786376953125,
      "height": 45,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1S",
      "roundness": null,
      "seed": 1833245301,
      "version": 113,
      "versionNonce": 819213909,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783641094397,
      "link": null,
      "locked": false,
      "text": "What are WebSockets?",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "What are WebSockets?",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "70uL3mRtAhyaxTUv3cI0d",
      "type": "text",
      "x": 4748.059215921782,
      "y": -6250.947286184842,
      "width": 1036.4191606987924,
      "height": 45,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1T",
      "roundness": null,
      "seed": 1500509333,
      "version": 251,
      "versionNonce": 1376035765,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783641094397,
      "link": null,
      "locked": false,
      "text": "The Inefficiency of HTTP for Real-Time Apps",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The Inefficiency of HTTP for Real-Time Apps",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "oyio3fRuhKjQhIhqo8l6W",
      "type": "text",
      "x": 4758.283327167169,
      "y": -6166.877526012,
      "width": 1042.2009053857753,
      "height": 135,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1U",
      "roundness": null,
      "seed": 757533499,
      "version": 307,
      "versionNonce": 1098933525,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783641094397,
      "link": null,
      "locked": false,
      "text": "If you try to build a real-time app (like a stock ticker)\nusing HTTP, the client must ask the server for updates\nconstantly (polling). This is highly inefficient because:",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "If you try to build a real-time app (like a stock ticker) using HTTP, the client must ask the server for updates constantly (polling). This is highly inefficient because:",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "7HFpIH2EZp47Pfp_5oJe9",
      "type": "text",
      "x": 4759.513834195863,
      "y": -6028.00864956453,
      "width": 797.1116943359375,
      "height": 135,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1b",
      "roundness": null,
      "seed": 421851643,
      "version": 246,
      "versionNonce": 1119681141,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783641094397,
      "link": null,
      "locked": false,
      "text": "Connection Overhead: Every HTTP request\nrequires a three-way TCP network handshake\n(request",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Connection Overhead: Every HTTP request requires a three-way TCP network handshake (request",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "k1XEINZLo5gDh-86oHTuy",
      "type": "text",
      "x": 4902.835062618681,
      "y": -5933.860883487651,
      "width": 257.5364990234375,
      "height": 45,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1d",
      "roundness": null,
      "seed": 357235355,
      "version": 327,
      "versionNonce": 243262421,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783641094397,
      "link": null,
      "locked": false,
      "text": "→ acknowledge",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "→ acknowledge",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "FaPqWMaTeUZtOquQ5PdSd",
      "type": "text",
      "x": 5159.874746783006,
      "y": -5933.453046368896,
      "width": 640.9003295898438,
      "height": 45,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1f",
      "roundness": null,
      "seed": 2095509307,
      "version": 315,
      "versionNonce": 685678901,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783641094397,
      "link": null,
      "locked": false,
      "text": "→ verify) ",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "→ verify) ",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "LssT-yU8nhfew5Rjfu3G8",
      "type": "text",
      "x": 4750.084902593487,
      "y": -5783.7494997240565,
      "width": 1066.0921397782897,
      "height": 135,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1g",
      "roundness": null,
      "seed": 1554970101,
      "version": 224,
      "versionNonce": 2000597653,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783641094397,
      "link": null,
      "locked": false,
      "text": "WebSockets Solution: The handshake happens only once.\nAfter the connection is opened, data flows back and forth\ninstantly with minimal overhead.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "WebSockets Solution: The handshake happens only once. After the connection is opened, data flows back and forth instantly with minimal overhead.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "yzcrOYwCsTGMifzh8g5on",
      "type": "text",
      "x": 4747.1316706585085,
      "y": -5881.789158912974,
      "width": 627.2637939453125,
      "height": 45,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1h",
      "roundness": null,
      "seed": 1944657115,
      "version": 215,
      "versionNonce": 374708213,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783641094397,
      "link": null,
      "locked": false,
      "text": "plus sending heavy request headers.",
      "fontSize": 36,
