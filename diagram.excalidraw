    {
      "id": "es1VW5UX8wQ9rr-eKvZKd",
      "type": "text",
      "x": -698.7299009581061,
      "y": -6757.776937339839,
      "width": 1663.5216644043794,
      "height": 1050,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
