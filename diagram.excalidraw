    {
      "id": "Hu0up-w3-dGPicI61Jihg",
      "type": "text",
      "x": 2218.624928858028,
      "y": -6277.668277556908,
      "width": 843.80871613575,
      "height": 810,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
