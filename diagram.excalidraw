    {
      "id": "h51dKdXSK-5vDdtz_Z5cU",
      "type": "text",
      "x": 8125.556210391374,
      "y": -5567.78136590892,
      "width": 582.6574585534162,
      "height": 82.27304112817363,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b20",
      "roundness": null,
      "seed": 1941308981,
      "version": 91,
      "versionNonce": 49546261,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783641350690,
      "link": null,
      "locked": false,
      "text": "1) The Ideal WebSocket Flow for\nCode Submission",
      "fontSize": 32.90921645126945,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1) The Ideal WebSocket Flow for Code Submission",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "gReCEgUZmxQxab9C2b_OO",
      "type": "text",
      "x": 8123.343146071819,
      "y": -5436.2194007081225,
      "width": 580.3922052157204,
      "height": 82.27304112817363,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b21",
      "roundness": null,
      "seed": 1329357723,
      "version": 112,
      "versionNonce": 1660986741,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783641360770,
      "link": null,
      "locked": false,
      "text": "Ideally, when you submit code on a\nplatform like LeetCode:",
      "fontSize": 32.90921645126945,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Ideally, when you submit code on a platform like LeetCode:",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "3QrG4VrT4jUzYaN1f3CfV",
      "type": "text",
      "x": 8127.606861849671,
      "y": -5330.701488826443,
      "width": 542.4232647237849,
      "height": 82.27304112817363,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b22",
      "roundness": null,
      "seed": 467761045,
      "version": 110,
      "versionNonce": 498367547,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783641362686,
      "link": null,
      "locked": false,
      "text": "The browser submits the code to\nthe primary backend.",
      "fontSize": 32.90921645126945,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The browser submits the code to the primary backend.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "NRNHZN4WYB94UXAv7SJWl",
      "type": "text",
      "x": 8128.455534791899,
      "y": -5223.227913367053,
      "width": 562.1381233511275,
      "height": 82.27304112817363,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b23",
      "roundness": null,
      "seed": 650328123,
      "version": 123,
      "versionNonce": 2032783573,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783641365418,
      "link": null,
      "locked": false,
      "text": "The backend pushes it onto a\nbackground queue for evaluation.",
      "fontSize": 32.90921645126945,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The backend pushes it onto a background queue for evaluation.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "luk3d6UOkV1mss98rExh-",
      "type": "text",
      "x": 8124.461751006302,
      "y": -5105.193677262082,
      "width": 586.1847081724209,
      "height": 287.9556439486077,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b24",
      "roundness": null,
      "seed": 72858869,
      "version": 103,
      "versionNonce": 320464283,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783641367319,
      "link": null,
      "locked": false,
      "text": "Once the background worker\nfinishes executing the code, it\nupdates the database and triggers\na WebSocket server to push the\nfinal status (e.g., Accepted, Wrong\nAnswer) back to the browser\ninstantly.",
      "fontSize": 32.90921645126945,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Once the background worker finishes executing the code, it updates the database and triggers a WebSocket server to push the final status (e.g., Accepted, Wrong Answer) back to the browser instantly.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "uOZ6UWf87J-3NuwZ27uVL",
      "type": "text",
      "x": 8762.436341463203,
      "y": -5562.164993447837,
      "width": 675.791748046875,
      "height": 45,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b25",
      "roundness": null,
      "seed": 1137534843,
      "version": 23,
      "versionNonce": 1636214997,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783641387987,
      "link": null,
      "locked": false,
      "text": "2) LeetCode's Actual Approach: Polling",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "2) LeetCode's Actual Approach: Polling",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "RnbeGhC5tzk4N-yYgvUxI",
      "type": "text",
      "x": 8766.371142564465,
      "y": -5465.512646700717,
      "width": 723.5862970820433,
      "height": 90,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b26",
      "roundness": null,
      "seed": 935010741,
      "version": 66,
      "versionNonce": 978109211,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783641405721,
      "link": null,
      "locked": false,
      "text": "Instead of using WebSockets, LeetCode\nuses Polling (sending repeated requests):",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Instead of using WebSockets, LeetCode uses Polling (sending repeated requests):",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "cL4dNQrXlGJSuMpCrc3Ny",
      "type": "text",
      "x": 8765.694208592042,
      "y": -5351.956523414442,
      "width": 694.1611420442752,
      "height": 90,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b27",
      "roundness": null,
      "seed": 239648795,
      "version": 57,
      "versionNonce": 951892443,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783641416488,
      "link": null,
      "locked": false,
      "text": "Submission: You click \"Submit\", and the\nbrowser sends the code to the server.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Submission: You click \"Submit\", and the browser sends the code to the server.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "xfCri2vaia86-ExWIoHi6",
      "type": "text",
      "x": 8756.433773539491,
      "y": -5235.689240331564,
      "width": 752.8289426727735,
      "height": 180,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b28",
      "roundness": null,
      "seed": 1740055317,
      "version": 61,
      "versionNonce": 1246031995,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783641420119,
      "link": null,
      "locked": false,
      "text": "Checking Status: The browser starts\nsending HTTP requests to a /check\nendpoint every 1 second (e.g., \"Is my\nsubmission done yet?\").",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Checking Status: The browser starts sending HTTP requests to a /check endpoint every 1 second (e.g., \"Is my submission done yet?\").",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "-gwylP6cJZXw-oldHhPqr",
      "type": "text",
      "x": 8762.193115175402,
      "y": -5036.95080355366,
      "width": 733.2810911102752,
      "height": 180,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b29",
      "roundness": null,
      "seed": 1829766331,
      "version": 67,
      "versionNonce": 1823103195,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783641421187,
      "link": null,
      "locked": false,
      "text": "Response: The server responds with\nstatus: pending until the background\nevaluation completes, at which point the\nserver returns the final execution result.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Response: The server responds with status: pending until the background evaluation completes, at which point the server returns the final execution result.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "iFP3b5XZ3dsYEIle7qfX7",
      "type": "text",
      "x": 9569.203066341435,
      "y": -5565.008759317763,
      "width": 680.9037475585938,
      "height": 45,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2A",
      "roundness": null,
      "seed": 114533051,
      "version": 79,
      "versionNonce": 368510997,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783641457049,
      "link": null,
      "locked": false,
      "text": "3) When to Use Polling vs. WebSockets",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "3) When to Use Polling vs. WebSockets",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "sdogu7LoycwDdMC2tNBp8",
      "type": "text",
      "x": 9564.050030573035,
      "y": -5459.450735486787,
      "width": 735.4659903827542,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2B",
      "roundness": null,
      "seed": 1001994869,
      "version": 146,
      "versionNonce": 800687509,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783641466271,
      "link": null,
      "locked": false,
      "text": "Polling: Works well for occasional or slow\nupdates where real-time instant\nresponsiveness isn't critical (such as\nwaiting for a code submission that takes\na few seconds).",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Polling: Works well for occasional or slow updates where real-time instant responsiveness isn't critical (such as waiting for a code submission that takes a few seconds).",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "nYBLpH8lks2Dz01Ifye_v",
      "type": "text",
      "x": 9568.993848797372,
      "y": -5213.953035197413,
      "width": 698.813370561822,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2C",
      "roundness": null,
      "seed": 1667601243,
      "version": 122,
      "versionNonce": 1783843579,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783641469788,
      "link": null,
      "locked": false,
      "text": "WebSockets: Essential for high-\nfrequency, real-time incoming data\nstreams (like crypto exchanges) where\npolling 30 times a second would crash\nthe server.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "WebSockets: Essential for high-frequency, real-time incoming data streams (like crypto exchanges) where polling 30 times a second would crash the server.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "7kzoUzNKqGjucAZVrRb2h",
      "type": "rectangle",
      "x": 3340.107196364893,
      "y": -7187.384179880011,
      "width": 7103.60943556885,
      "height": 2921.8125915527344,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2D",
      "roundness": {
        "type": 3
      },
      "seed": 466454101,
      "version": 125,
      "versionNonce": 1610586139,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783641874947,
      "link": null,
      "locked": false
    },
    {
      "id": "C7Ng_JEmazYeS1NLcGpAB",
      "type": "text",
      "x": 3655.0319204658144,
      "y": -6963.1879795989935,
      "width": 1106.2677840099504,
      "height": 244.27401732554233,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2F",
      "roundness": null,
      "seed": 1071485109,
